<% content_for(:title) { "#{@prefecture.name}の店舗一覧 - ヨミスロ" } %>

<%# JSON-LD structured data %>
<% content_for(:head) do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "#{@prefecture.name}のパチスロ店舗一覧",
      "description": "#{@prefecture.name}のパチスロ店舗#{@total_shops_count}件の設定・リセット記録情報",
      "url": request.original_url.split("?").first,
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "ホーム", "item": root_url },
          { "@type": "ListItem", "position": 2, "name": @prefecture.name }
        ]
      },
      "numberOfItems": @total_shops_count
    }.to_json) %>
  </script>
<% end %>

<section class="mt-6 mb-8">
  <%# パンくずリスト %>
  <nav aria-label="breadcrumb" class="mb-5">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li class="inline-flex items-center gap-1.5">
        <%= link_to root_path, class: "hover:text-foreground transition-colors" do %>
          <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
          <span>ホーム</span>
        <% end %>
      </li>
      <li aria-hidden="true">
        <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </li>
      <li>
        <span class="text-foreground font-normal" aria-current="page"><%= @prefecture.name %></span>
      </li>
    </ol>
  </nav>

  <%# ページヘッダー %>
  <div class="flex items-baseline justify-between mb-6">
    <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground"><%= @prefecture.name %></h1>
    <span class="text-sm text-muted-foreground tabular-nums"><%= @total_shops_count %> 店舗</span>
  </div>

  <%# Wrap stats + filter + list in one controller scope for stat-to-filter linking %>
  <div data-controller="shop-filter machine-filter">

  <%# 統計セクション %>
  <% if @total_shops_count > 0 %>
    <%
      top_exchange = @exchange_rate_stats.first
      top_rate = @slot_rate_stats.first
      top_opening = @opening_hours_stats.max_by { |_, v| v }
      top_closing = @closing_hours_stats.max_by { |_, v| v }
      display_facilities = @facility_stats.select { |f, _|
        %w[Wi-Fi 充電器 屋内喫煙室 加熱式たばこ遊技OK 加熱式たばこ喫煙室 加熱式たばこ 出玉公開].include?(f)
      }
      exchange_display_to_value = { "等価" => "equal_rate", "5.6枚交換" => "rate_56", "5.0枚交換" => "rate_50", "非等価" => "non_equal" }
    %>
    <div class="bg-card rounded-lg border-b border-border/50 p-5 mb-6 cursor-pointer hover:shadow-sm transition-all"
         data-controller="accordion" data-action="click->accordion#toggle">
      <%# サマリー行: 常に表示 %>
      <div class="flex flex-wrap items-center gap-2 text-xs">
        <% if top_exchange %>
          <button type="button"
                  data-action="click->shop-filter#applyPreset"
                  data-preset-category="exchange"
                  data-preset-value="<%= exchange_display_to_value[top_exchange[0]] %>"
                  class="inline-flex items-center rounded-md border border-transparent bg-slot-green/10 text-slot-green font-medium px-2.5 py-0.5 text-xs hover:bg-slot-green/20 transition-colors">
            <%= top_exchange[0] %> <%= (top_exchange[1] * 100.0 / @total_shops_count).round %>%
          </button>
        <% end %>
        <% if top_rate %>
          <button type="button"
                  data-action="click->shop-filter#applyPreset"
                  data-preset-category="rates"
                  data-preset-value="<%= top_rate[0] %>"
                  class="inline-flex items-center rounded-md border border-transparent bg-slot-blue/10 text-slot-blue font-medium px-2.5 py-0.5 text-xs hover:bg-slot-blue/20 transition-colors">
            <%= top_rate[0] %> <%= (top_rate[1] * 100.0 / @total_shops_count).round %>%
          </button>
        <% end %>
        <% if top_opening %>
          <%
            opening_filter_value = top_opening[0].match(/\A(\d{1,2}):/)[1] rescue nil
          %>
          <% if opening_filter_value %>
            <button type="button"
                    data-action="click->shop-filter#applyPreset"
                    data-preset-category="hours"
                    data-preset-value="<%= opening_filter_value %>"
                    class="inline-flex items-center rounded-md border border-transparent bg-slot-yellow/10 text-slot-yellow font-medium px-2.5 py-0.5 text-xs hover:bg-slot-yellow/20 transition-colors">
              開店 <%= top_opening[0] %> <%= (top_opening[1] * 100.0 / @total_shops_count).round %>%
            </button>
          <% end %>
        <% end %>
        <% if top_closing %>
          <span class="inline-flex items-center rounded-md border border-transparent bg-slot-red/10 text-slot-red font-medium px-2.5 py-0.5 text-xs">
            閉店 <%= top_closing[0] %> <%= (top_closing[1] * 100.0 / @total_shops_count).round %>%
          </span>
        <% end %>
        <% display_facilities.first(2).each do |facility, count| %>
          <%
            facility_filter_value = %w[Wi-Fi 充電器 加熱式たばこ遊技OK].include?(facility) ? facility : nil
          %>
          <% if facility_filter_value %>
            <button type="button"
                    data-action="click->shop-filter#applyPreset"
                    data-preset-category="facilities"
                    data-preset-value="<%= facility_filter_value %>"
                    class="inline-flex items-center rounded-md border border-border bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs hover:bg-secondary/80 transition-colors">
              <%= facility %> <%= (count * 100.0 / @total_shops_count).round %>%
            </button>
          <% else %>
            <span class="inline-flex items-center rounded-md border border-border bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs">
              <%= facility %> <%= (count * 100.0 / @total_shops_count).round %>%
            </span>
          <% end %>
        <% end %>
        <svg data-accordion-target="icon" class="w-4 h-4 text-muted-foreground transition-transform duration-200 ml-auto shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>

      <%# 詳細: 展開時のみ表示 %>
      <div data-accordion-target="content" class="hidden mt-5 pt-4 border-t border-border">
        <p class="text-[10px] text-muted-foreground mb-4">各項目をクリックすると店舗を絞り込めます</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

          <% if @exchange_rate_stats.any? %>
            <div>
              <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">換金率</h3>
              <div class="space-y-2">
                <% @exchange_rate_stats.each do |label, count| %>
                  <% pct = (count * 100.0 / @total_shops_count).round(1) %>
                  <button type="button"
                          data-action="click->shop-filter#applyPreset"
                          data-preset-category="exchange"
                          data-preset-value="<%= exchange_display_to_value[label] %>"
                          class="w-full flex items-center gap-2.5 rounded-md px-2 py-1 -mx-2 hover:bg-slot-green/10 transition-colors cursor-pointer group"
                          data-stat-filter>
                    <span class="text-xs text-foreground w-20 shrink-0 group-hover:text-slot-green group-hover:font-semibold transition-all"><%= label %></span>
                    <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                      <div class="bg-slot-green h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                    </div>
                    <span class="text-[10px] text-muted-foreground w-16 text-right shrink-0 tabular-nums"><%= count %>店 (<%= pct %>%)</span>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @slot_rate_stats.any? %>
            <div>
              <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">スロットレート</h3>
              <div class="space-y-2">
                <% @slot_rate_stats.each do |rate, count| %>
                  <% pct = (count * 100.0 / @total_shops_count).round(1) %>
                  <button type="button"
                          data-action="click->shop-filter#applyPreset"
                          data-preset-category="rates"
                          data-preset-value="<%= rate %>"
                          class="w-full flex items-center gap-2.5 rounded-md px-2 py-1 -mx-2 hover:bg-slot-blue/10 transition-colors cursor-pointer group"
                          data-stat-filter>
                    <span class="text-xs text-foreground w-20 shrink-0 group-hover:text-slot-blue group-hover:font-semibold transition-all"><%= rate %></span>
                    <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                      <div class="bg-slot-blue h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                    </div>
                    <span class="text-[10px] text-muted-foreground w-16 text-right shrink-0 tabular-nums"><%= count %>店 (<%= pct %>%)</span>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if display_facilities.any? %>
            <div>
              <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">設備</h3>
              <div class="space-y-2">
                <% display_facilities.each do |facility, count| %>
                  <% pct = (count * 100.0 / @total_shops_count).round(1) %>
                  <%
                    filterable_facility = %w[Wi-Fi 充電器 加熱式たばこ遊技OK].include?(facility)
                    facility_value = facility == "parking" ? "parking" : facility
                  %>
                  <% if filterable_facility %>
                    <button type="button"
                            data-action="click->shop-filter#applyPreset"
                            data-preset-category="facilities"
                            data-preset-value="<%= facility_value %>"
                            class="w-full flex items-center gap-2.5 rounded-md px-2 py-1 -mx-2 hover:bg-slot-red/10 transition-colors cursor-pointer group"
                            data-stat-filter>
                      <span class="text-xs text-foreground w-28 shrink-0 truncate group-hover:text-slot-red group-hover:font-semibold transition-all"><%= facility %></span>
                      <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                        <div class="bg-slot-red h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                      </div>
                      <span class="text-[10px] text-muted-foreground w-12 text-right shrink-0 tabular-nums"><%= pct %>%</span>
                    </button>
                  <% else %>
                    <div class="flex items-center gap-2.5 px-2 py-1 -mx-2">
                      <span class="text-xs text-foreground w-28 shrink-0 truncate"><%= facility %></span>
                      <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                        <div class="bg-slot-red h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                      </div>
                      <span class="text-[10px] text-muted-foreground w-12 text-right shrink-0 tabular-nums"><%= pct %>%</span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @opening_hours_stats.any? %>
            <div>
              <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">開店時間</h3>
              <div class="space-y-2">
                <% @opening_hours_stats.each do |hour, count| %>
                  <% pct = (count * 100.0 / @total_shops_count).round(1) %>
                  <%
                    hour_filter_value = hour.match(/\A(\d{1,2}):/)[1] rescue nil
                  %>
                  <% if hour_filter_value && %w[9 10].include?(hour_filter_value) %>
                    <button type="button"
                            data-action="click->shop-filter#applyPreset"
                            data-preset-category="hours"
                            data-preset-value="<%= hour_filter_value %>"
                            class="w-full flex items-center gap-2.5 rounded-md px-2 py-1 -mx-2 hover:bg-slot-yellow/10 transition-colors cursor-pointer group"
                            data-stat-filter>
                      <span class="text-xs text-foreground w-20 shrink-0 group-hover:text-slot-yellow group-hover:font-semibold transition-all"><%= hour %></span>
                      <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                        <div class="bg-slot-yellow h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                      </div>
                      <span class="text-[10px] text-muted-foreground w-16 text-right shrink-0 tabular-nums"><%= count %>店 (<%= pct %>%)</span>
                    </button>
                  <% else %>
                    <div class="flex items-center gap-2.5 px-2 py-1 -mx-2">
                      <span class="text-xs text-foreground w-20 shrink-0"><%= hour %></span>
                      <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                        <div class="bg-slot-yellow h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                      </div>
                      <span class="text-[10px] text-muted-foreground w-16 text-right shrink-0 tabular-nums"><%= count %>店 (<%= pct %>%)</span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @closing_hours_stats.any? %>
            <div>
              <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">閉店時間</h3>
              <div class="space-y-2">
                <% @closing_hours_stats.each do |hour, count| %>
                  <% pct = (count * 100.0 / @total_shops_count).round(1) %>
                  <div class="flex items-center gap-2.5 px-2 py-1 -mx-2">
                    <span class="text-xs text-foreground w-20 shrink-0"><%= hour %></span>
                    <div class="flex-1 h-1.5 bg-secondary rounded-full overflow-hidden">
                      <div class="bg-slot-red h-full rounded-full transition-all" style="width: <%= pct %>%"></div>
                    </div>
                    <span class="text-[10px] text-muted-foreground w-16 text-right shrink-0 tabular-nums"><%= count %>店 (<%= pct %>%)</span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# 駐車場・朝入場 %>
          <div>
            <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">その他</h3>
            <div class="space-y-2">
              <% if @parking_stats[:total] > 0 %>
                <button type="button"
                        data-action="click->shop-filter#applyPreset"
                        data-preset-category="facilities"
                        data-preset-value="parking"
                        class="w-full flex items-center justify-between text-xs rounded-md px-2 py-1.5 -mx-2 hover:bg-slot-red/10 transition-colors cursor-pointer group"
                        data-stat-filter>
                  <span class="text-foreground group-hover:text-slot-red group-hover:font-semibold transition-all">駐車場あり</span>
                  <span class="text-muted-foreground tabular-nums"><%= @parking_stats[:total] %>店 / 平均<%= @parking_stats[:avg] %>台 / 最大<%= @parking_stats[:max] %>台</span>
                </button>
              <% end %>
              <% if @morning_entry_count > 0 %>
                <button type="button"
                        data-action="click->shop-filter#applyPreset"
                        data-preset-category="morning"
                        data-preset-value="yes"
                        class="w-full flex items-center justify-between text-xs rounded-md px-2 py-1.5 -mx-2 hover:bg-slot-yellow/10 transition-colors cursor-pointer group"
                        data-stat-filter>
                  <span class="text-foreground group-hover:text-slot-yellow group-hover:font-semibold transition-all">朝の入場ルールあり</span>
                  <span class="text-muted-foreground tabular-nums"><%= @morning_entry_count %>店</span>
                </button>
              <% end %>
            </div>
          </div>

        </div>
      </div>
    </div>
  <% end %>

  <%# おすすめ店舗 %>
  <% if @recommendations.present? %>
    <div class="mb-6">
      <h2 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
        おすすめ店舗
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
        <% @recommendations.each_with_index do |rec, i| %>
          <%= link_to shop_path(rec.shop.slug), class: "bg-card rounded-lg border-b border-border/50 p-3.5 hover:-translate-y-px hover:shadow-sm transition-all duration-150 block" do %>
            <div class="flex items-center gap-2.5">
              <span class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold tabular-nums
                <%= case i when 0 then 'bg-primary/15 text-primary' when 1 then 'bg-slot-blue/15 text-slot-blue' else 'bg-secondary text-muted-foreground' end %>">
                <%= i + 1 %>
              </span>
              <p class="font-semibold text-sm text-foreground truncate"><%= favorite_mark(rec.shop) %> <%= rec.shop.name %></p>
            </div>
            <% if rec.reasons.any? %>
              <div class="flex flex-wrap gap-1 mt-2 ml-7">
                <% rec.reasons.first(2).each do |reason| %>
                  <%
                    badge_class = case reason[:type]
                    when :high_setting then "bg-slot-red/10 text-slot-red"
                    when :reset_rate then "bg-slot-green/10 text-slot-green"
                    when :vote_volume then "bg-slot-blue/10 text-slot-blue"
                    when :review_rating then "bg-slot-yellow/10 text-slot-yellow"
                    else "bg-secondary text-muted-foreground"
                    end
                  %>
                  <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-md <%= badge_class %>">
                    <%= reason[:label] %>
                  </span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# 県の収支統計 %>
  <% pref_summary = PlayRecordSummary.find_by(scope_type: "prefecture", scope_id: @prefecture.id, period_type: :all_time, period_key: "all") %>
  <% if pref_summary && pref_summary.total_records >= 5 %>
    <div class="bg-surface-inset rounded-lg p-4 mb-6">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-slot-yellow rounded-full"></span>
        <%= @prefecture.name %>の収支統計
      </h2>
      <div class="grid grid-cols-3 gap-3">
        <div class="text-center">
          <p class="text-lg font-bold tabular-nums <%= pref_summary.avg_result >= 0 ? 'text-primary' : 'text-destructive' %>">
            <%= pref_summary.avg_result >= 0 ? '+' : '' %><%= number_with_delimiter(pref_summary.avg_result) %>円
          </p>
          <p class="text-xs text-muted-foreground">平均収支</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold tabular-nums text-foreground"><%= pref_summary.win_rate %>%</p>
          <p class="text-xs text-muted-foreground">勝率</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold tabular-nums text-foreground"><%= pref_summary.total_records %></p>
          <p class="text-xs text-muted-foreground">記録数</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# 店舗名検索 %>
  <div class="relative mb-3">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-muted-foreground pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input type="text"
           data-action="input->machine-filter#filter"
           data-machine-filter-target="input"
           placeholder="店舗名で絞り込み..."
           aria-label="店舗名で絞り込み"
           class="w-full min-h-[44px] rounded-md border border-input bg-transparent pl-9 pr-3 py-2 text-sm shadow-xs placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] outline-none transition-[color,box-shadow]">
  </div>

  <%# フィルタパネル %>
  <div class="mb-5">
    <div class="flex items-center justify-between">
      <button type="button"
              data-action="click->shop-filter#toggle"
              class="inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 font-medium transition-colors min-h-[44px]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
        </svg>
        <span data-shop-filter-target="toggleText">絞り込み</span>
        <svg data-shop-filter-target="toggleIcon" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <span data-filter-counter class="text-xs text-muted-foreground tabular-nums">
        <span data-shop-filter-target="count">0</span>件 / 全<span data-shop-filter-target="total">0</span>件
      </span>
    </div>

    <div data-shop-filter-target="panel" class="hidden mt-3 bg-card rounded-lg border-b border-border/50 p-5 shadow-sm">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <%# 換金率 %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">換金率</h4>
          <div class="space-y-2">
            <% [["equal_rate", "等価"], ["rate_56", "5.6枚交換"], ["rate_50", "5.0枚交換"], ["non_equal", "非等価"]].each do |value, label| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="<%= value %>"
                       data-filter-category="exchange"
                       data-shop-filter-target="checkbox"
                       data-action="change->shop-filter#apply"
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# レート %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">レート</h4>
          <div class="space-y-2">
            <% %w[20スロ 5スロ 2スロ 1スロ].each do |rate| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="<%= rate %>"
                       data-filter-category="rates"
                       data-shop-filter-target="checkbox"
                       data-action="change->shop-filter#apply"
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= rate %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# 設備 %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">設備</h4>
          <div class="space-y-2">
            <% [["加熱式たばこ遊技OK", "加熱式たばこ遊技OK"], ["Wi-Fi", "Wi-Fi"], ["充電器", "充電器"], ["parking", "駐車場あり"]].each do |value, label| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="<%= value %>"
                       data-filter-category="facilities"
                       data-shop-filter-target="checkbox"
                       data-action="change->shop-filter#apply"
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# 開店時間 %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">開店時間</h4>
          <div class="space-y-2">
            <% [["9", "9時台"], ["10", "10時台"]].each do |value, label| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="<%= value %>"
                       data-filter-category="hours"
                       data-shop-filter-target="checkbox"
                       data-action="change->shop-filter#apply"
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# 朝入場ルール %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">朝入場ルール</h4>
          <div class="space-y-2">
            <label class="flex items-center gap-2.5 cursor-pointer group">
              <input type="checkbox" value="yes"
                     data-filter-category="morning"
                     data-shop-filter-target="checkbox"
                     data-action="change->shop-filter#apply"
                     class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
              <span class="text-xs text-foreground group-hover:text-primary transition-colors">ルールあり</span>
            </label>
          </div>
        </div>

      </div>

      <%# クリアボタン %>
      <div class="mt-4 pt-3 border-t border-border">
        <button type="button"
                data-action="click->shop-filter#clear"
                class="text-xs text-muted-foreground hover:text-foreground transition-colors underline underline-offset-2 min-h-[44px] px-2">
          フィルタをクリア
        </button>
      </div>
    </div>
  </div>

  <%# 店舗一覧 %>
  <% if @grouped_shops.any? %>
    <div data-machine-filter-target="list" class="space-y-3">
      <% @grouped_shops.each_with_index do |(city, shops), idx| %>
        <div data-controller="accordion" data-city-group>
          <button type="button" data-action="click->accordion#toggle"
                  class="w-full flex items-center justify-between bg-card rounded-lg border-b border-border/50 px-4 py-3 hover:shadow-sm transition-all min-h-[44px]">
            <div class="flex items-center gap-2.5">
              <span class="text-sm font-semibold text-foreground"><%= city %></span>
              <span data-city-count class="text-[11px] text-muted-foreground bg-secondary rounded-md px-2 py-0.5 tabular-nums"><%= shops.size %>店</span>
            </div>
            <svg data-accordion-target="icon" class="w-4 h-4 text-muted-foreground transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div data-accordion-target="content" class="hidden mt-2">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
              <% shops.each do |shop| %>
                <%
                  facilities = shop.notes.present? ? shop.notes.split("、").map(&:strip) : []
                  if shop.parking_spaces.present? && shop.parking_spaces > 0
                    facilities << "parking"
                  end
                  opening_hour = ""
                  if shop.business_hours.present?
                    parts = shop.business_hours.split(/[〜～]/).map(&:strip)
                    if (m = parts[0]&.match(/\A(\d{1,2}):\d{2}\z/))
                      opening_hour = m[1]
                    end
                  end
                %>
                <%= link_to shop_path(shop.slug),
                    class: "bg-card rounded-lg border-b border-border/50 p-3.5 hover:-translate-y-px hover:shadow-sm transition-all duration-150 block h-full",
                    data: {
                      filter_name: shop.name.downcase,
                      shop_card: true,
                      filter_exchange: shop.exchange_rate,
                      filter_rates: shop.slot_rates.present? ? shop.slot_rates.join(",") : "",
                      filter_facilities: facilities.join(","),
                      filter_hours: opening_hour,
                      filter_morning: shop.morning_entry.present? ? "yes" : "no"
                    } do %>
                  <div class="flex items-start justify-between gap-2">
                    <p class="font-semibold text-sm text-foreground truncate flex-1"><%= favorite_mark(shop) %> <%= shop.name %></p>
                    <% if shop.exchange_rate != "unknown_rate" %>
                      <span class="shrink-0 text-[10px] font-medium px-2 py-0.5 rounded-md
                        <%= case shop.exchange_rate
                            when 'equal_rate' then 'bg-slot-green/10 text-slot-green'
                            when 'rate_56' then 'bg-slot-yellow/10 text-slot-yellow'
                            when 'rate_50' then 'bg-slot-yellow/15 text-slot-yellow'
                            when 'non_equal' then 'bg-secondary text-muted-foreground'
                            end %>">
                        <%= shop.exchange_rate_display %>
                      </span>
                    <% end %>
                  </div>
                  <div class="flex flex-wrap items-center gap-1 mt-2">
                    <% if shop.slot_rates.present? %>
                      <% shop.slot_rates.each do |rate| %>
                        <span class="bg-slot-blue/10 text-slot-blue text-[10px] font-medium px-1.5 py-0.5 rounded-md"><%= rate %></span>
                      <% end %>
                    <% end %>
                    <% machine_count = shop.shop_machine_models.size %>
                    <% if machine_count > 0 %>
                      <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md tabular-nums"><%= machine_count %>機種</span>
                    <% end %>
                    <% if shop.notes.present? %>
                      <% shop_facilities = shop.notes.split("、") %>
                      <% if shop_facilities.include?("加熱式たばこ遊技OK") %>
                        <span class="bg-slot-green/10 text-slot-green text-[10px] font-medium px-1.5 py-0.5 rounded-md">遊技中OK</span>
                      <% elsif shop_facilities.include?("加熱式たばこ喫煙室") %>
                        <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">喫煙室</span>
                      <% elsif shop_facilities.include?("加熱式たばこ") %>
                        <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">加熱式</span>
                      <% end %>
                      <% if shop_facilities.include?("Wi-Fi") %>
                        <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">Wi-Fi</span>
                      <% end %>
                      <% if shop_facilities.include?("充電器") %>
                        <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">充電</span>
                      <% end %>
                    <% end %>
                    <% if shop.parking_spaces.present? && shop.parking_spaces > 0 %>
                      <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md tabular-nums">P<%= shop.parking_spaces %></span>
                    <% end %>
                    <% if shop.morning_entry.present? %>
                      <span class="bg-slot-yellow/10 text-slot-yellow text-[10px] font-medium px-1.5 py-0.5 rounded-md">朝整理券</span>
                    <% end %>
                    <% if @review_averages[shop.id] %>
                      <span class="text-slot-yellow text-[10px] font-medium tabular-nums">★ <%= @review_averages[shop.id] %></span>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-card rounded-lg border-b border-border/50 p-8 text-center mt-4">
      <p class="text-muted-foreground">この都道府県にはまだ店舗が登録されていません。</p>
    </div>
  <% end %>
  </div>
</section>
