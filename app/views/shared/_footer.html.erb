<footer class="mt-12">
  <div class="h-px w-full bg-border/50"></div>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <%# Links %>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        <%= link_to rankings_path,
              class: "text-muted-foreground transition-colors hover:text-foreground inline-flex items-center gap-1.5 py-2 min-h-[44px]" do %>
          ランキング
        <% end %>
        <%= link_to play_records_path,
              class: "text-muted-foreground transition-colors hover:text-foreground inline-flex items-center gap-1.5 py-2 min-h-[44px]" do %>
          収支カレンダー
        <% end %>
        <%= link_to new_feedback_path,
              class: "text-muted-foreground transition-colors hover:text-foreground inline-flex items-center gap-1.5 py-2 min-h-[44px]" do %>
          <%= icon_message("w-4 h-4") %>
          ご意見・ご要望
        <% end %>
        <%= link_to new_shop_request_path,
              class: "text-muted-foreground transition-colors hover:text-foreground inline-flex items-center gap-1.5 py-2 min-h-[44px]" do %>
          <%= icon_plus_circle("w-4 h-4") %>
          店舗追加リクエスト
        <% end %>
      </div>

      <%# Copyright %>
      <div class="text-xs text-muted-foreground text-center sm:text-right">
        <p>&copy; <%= Date.current.year %> ヨミスロ</p>
        <p class="mt-0.5">匿名・無料のパチスロ総合データサイト</p>
        <p class="mt-1 text-[10px] text-muted-foreground/50">当サイトはパチスロメーカーとは無関係の個人プロジェクトです</p>
      </div>
    </div>
  </div>
</footer>
