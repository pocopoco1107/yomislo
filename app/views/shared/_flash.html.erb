<% if notice %>
  <div class="flex items-start gap-3 rounded-lg border border-primary/20 bg-primary/5 px-4 py-3 mb-4 animate-fade-in"
       data-controller="dismissable">
    <div class="shrink-0 text-primary mt-0.5">
      <%= icon_check_circle("w-5 h-5") %>
    </div>
    <p class="flex-1 text-sm text-foreground"><%= notice %></p>
    <button type="button"
            class="shrink-0 text-muted-foreground hover:text-foreground transition-colors min-w-[44px] min-h-[44px] inline-flex items-center justify-center -my-2 -mr-2"
            data-action="click->dismissable#dismiss"
            aria-label="閉じる">
      <%= icon_x("w-4 h-4") %>
    </button>
  </div>
<% end %>

<% if alert %>
  <div class="flex items-start gap-3 rounded-lg border border-destructive/20 bg-destructive/5 px-4 py-3 mb-4 animate-fade-in"
       data-controller="dismissable">
    <div class="shrink-0 text-destructive mt-0.5">
      <%= icon_exclamation_circle("w-5 h-5") %>
    </div>
    <p class="flex-1 text-sm text-foreground"><%= alert %></p>
    <button type="button"
            class="shrink-0 text-muted-foreground hover:text-foreground transition-colors min-w-[44px] min-h-[44px] inline-flex items-center justify-center -my-2 -mr-2"
            data-action="click->dismissable#dismiss"
            aria-label="閉じる">
      <%= icon_x("w-4 h-4") %>
    </button>
  </div>
<% end %>
