<% content_for(:title) { "店舗追加リクエスト ##{@shop_request.id} - スロリセnavi" } %>

<section class="mt-4 max-w-lg mx-auto">
  <h1 class="text-xl font-bold text-foreground mb-4">店舗追加リクエスト #<%= @shop_request.id %></h1>

  <div class="bg-card border border-border rounded-lg p-5">
    <dl class="space-y-3 text-sm">
      <div>
        <dt class="font-medium text-muted-foreground">ステータス</dt>
        <dd class="mt-0.5">
          <% case @shop_request.status %>
          <% when "pending" %>
            <span class="inline-flex items-center rounded-md bg-setting-4/10 px-2.5 py-0.5 text-xs font-medium text-setting-4 border border-setting-4/20">審査待ち</span>
          <% when "approved" %>
            <span class="inline-flex items-center rounded-md bg-vote-yes/10 px-2.5 py-0.5 text-xs font-medium text-vote-yes border border-vote-yes/20">承認済み</span>
          <% when "rejected" %>
            <span class="inline-flex items-center rounded-md bg-destructive/10 px-2.5 py-0.5 text-xs font-medium text-destructive border border-destructive/20">却下</span>
          <% end %>
        </dd>
      </div>

      <div>
        <dt class="font-medium text-muted-foreground">都道府県</dt>
        <dd class="mt-0.5 text-foreground"><%= @shop_request.prefecture.name %></dd>
      </div>

      <div>
        <dt class="font-medium text-muted-foreground">店舗名</dt>
        <dd class="mt-0.5 text-foreground"><%= @shop_request.name %></dd>
      </div>

      <% if @shop_request.address.present? %>
        <div>
          <dt class="font-medium text-muted-foreground">住所</dt>
          <dd class="mt-0.5 text-foreground"><%= @shop_request.address %></dd>
        </div>
      <% end %>

      <% if @shop_request.url.present? %>
        <div>
          <dt class="font-medium text-muted-foreground">公式サイト</dt>
          <dd class="mt-0.5"><%= link_to @shop_request.url, @shop_request.url, target: "_blank", rel: "noopener", class: "text-primary hover:underline break-all" %></dd>
        </div>
      <% end %>

      <% if @shop_request.note.present? %>
        <div>
          <dt class="font-medium text-muted-foreground">補足情報</dt>
          <dd class="mt-0.5 text-foreground"><%= simple_format(@shop_request.note) %></dd>
        </div>
      <% end %>

      <div>
        <dt class="font-medium text-muted-foreground">申請日時</dt>
        <dd class="mt-0.5 text-foreground"><%= l(@shop_request.created_at, format: :long) rescue @shop_request.created_at.strftime("%Y年%m月%d日 %H:%M") %></dd>
      </div>

      <% if @shop_request.rejected? && @shop_request.admin_note.present? %>
        <div>
          <dt class="font-medium text-muted-foreground">管理者メモ</dt>
          <dd class="mt-0.5 text-destructive"><%= @shop_request.admin_note %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="mt-4 text-center">
    <%= link_to "新しいリクエストを送信", new_shop_request_path, class: "text-sm text-primary hover:underline inline-flex items-center justify-center min-h-[44px] px-4" %>
  </div>
</section>
