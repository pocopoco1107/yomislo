<% content_for(:title) { "#{@shop.name} - スロリセnavi" } %>

<%# JSON-LD structured data for LocalBusiness %>
<% content_for(:head) do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "AmusementPark",
      "name": @shop.name,
      "description": "#{@shop.name}のパチスロ設定・リセット投票情報",
      "address": @shop.address.present? ? {
        "@type": "PostalAddress",
        "addressRegion": @shop.prefecture.name,
        "streetAddress": @shop.address
      } : nil,
      "telephone": @shop.phone_number.presence,
      "openingHours": @shop.business_hours.presence,
      "url": request.original_url.split("?").first,
      "aggregateRating": @average_rating ? {
        "@type": "AggregateRating",
        "ratingValue": @average_rating,
        "bestRating": 5,
        "worstRating": 1,
        "ratingCount": @reviews.size
      } : nil
    }.compact.to_json) %>
  </script>
<% end %>

<section class="mt-4">
  <%# === Breadcrumb === %>
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li class="inline-flex items-center gap-1.5">
        <%= link_to "ホーム", root_path, class: "hover:text-foreground transition-colors" %>
      </li>
      <li aria-hidden="true">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </li>
      <li class="inline-flex items-center gap-1.5">
        <%= link_to @shop.prefecture.name, prefecture_path(@shop.prefecture.slug), class: "hover:text-foreground transition-colors" %>
      </li>
      <li aria-hidden="true">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </li>
      <li class="inline-flex items-center gap-1.5">
        <span class="text-foreground font-normal"><%= @shop.name %></span>
      </li>
    </ol>
  </nav>

  <%# === Shop Header === %>
  <div class="bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center gap-2">
      <h1 class="text-2xl md:text-3xl font-bold text-foreground tracking-tight flex-1"><%= @shop.name %></h1>
      <div data-controller="favorite" data-favorite-shop-slug-value="<%= @shop.slug %>">
        <button data-action="click->favorite#toggle"
                class="text-2xl leading-none p-1 hover:scale-110 transition-transform min-w-[44px] min-h-[44px] inline-flex items-center justify-center"
                title="お気に入り">
          <span data-favorite-star class="text-muted-foreground">&#9734;</span>
        </button>
      </div>
    </div>
    <p class="text-sm text-muted-foreground mt-1">
      <%= @shop.prefecture.name %>
      <% if @shop.address.present? %>
        / <%= @shop.address %>
      <% end %>
    </p>
    <div class="flex flex-wrap items-center gap-3 mt-1.5 text-xs text-muted-foreground">
      <% if @shop.phone_number.present? %>
        <a href="tel:<%= @shop.phone_number %>" class="hover:text-primary transition-colors inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <%= @shop.phone_number %>
        </a>
      <% end %>
      <% if @shop.access_info.present? %>
        <span class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <%= @shop.access_info %>
        </span>
      <% end %>
      <% if @shop.pworld_url.present? %>
        <a href="<%= @shop.pworld_url %>" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline inline-flex items-center gap-1" aria-label="P-WORLDで店舗情報を見る（外部サイト）">
          P-WORLD
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      <% end %>
    </div>
  </div>

  <%# === Shop Info Card === %>
  <div class="bg-card border border-border rounded-lg p-4 mb-6">
    <h2 class="text-sm font-semibold text-foreground mb-3 border-b border-border pb-2">店舗情報</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-3 gap-x-4 text-sm">
      <div>
        <span class="text-xs text-muted-foreground block">レート</span>
        <span class="font-medium text-foreground"><%= @shop.slot_rates_display %></span>
      </div>
      <div>
        <span class="text-xs text-muted-foreground block">換金率</span>
        <span class="font-medium text-foreground"><%= @shop.exchange_rate_display %></span>
      </div>
      <div>
        <span class="text-xs text-muted-foreground block">スロット台数</span>
        <span class="font-medium text-foreground"><%= @shop.slot_machines || "未設定" %><%= "台" if @shop.slot_machines %></span>
      </div>
      <div>
        <span class="text-xs text-muted-foreground block">総台数</span>
        <span class="font-medium text-foreground"><%= @shop.total_machines || "未設定" %><%= "台" if @shop.total_machines %></span>
      </div>
      <div>
        <span class="text-xs text-muted-foreground block">営業時間</span>
        <span class="font-medium text-foreground"><%= @shop.business_hours || "未設定" %></span>
      </div>
      <% if @shop.parking_spaces.present? %>
        <div>
          <span class="text-xs text-muted-foreground block">駐車場</span>
          <span class="font-medium text-foreground"><%= @shop.parking_spaces %>台</span>
        </div>
      <% end %>
      <% if @shop.opened_on.present? %>
        <div>
          <span class="text-xs text-muted-foreground block">オープン日</span>
          <span class="font-medium text-foreground"><%= @shop.opened_on.strftime("%Y年%m月%d日") %></span>
        </div>
      <% end %>
      <% if @shop.former_event_days.present? %>
        <div class="col-span-2 sm:col-span-3">
          <span class="text-xs text-muted-foreground block">旧イベント日</span>
          <span class="font-medium text-destructive"><%= @shop.former_event_days %></span>
        </div>
      <% end %>
      <% if @shop.morning_entry.present? %>
        <div class="col-span-2 sm:col-span-3">
          <span class="text-xs text-muted-foreground block">朝の入場</span>
          <span class="font-medium text-primary"><%= @shop.morning_entry %></span>
        </div>
      <% end %>
      <% if @shop.features.present? %>
        <div class="col-span-2 sm:col-span-3">
          <span class="text-xs text-muted-foreground block">特徴</span>
          <span class="font-medium text-foreground"><%= @shop.features %></span>
        </div>
      <% end %>
    </div>
    <% if @shop.notes.present? %>
      <%
        display_map = {
          "Wi-Fi" => ["📶", "Wi-Fi"],
          "充電器" => ["🔌", "充電器"],
          "屋内喫煙室" => ["🚬", "喫煙室あり"],
          "加熱式たばこ遊技OK" => ["🚬", "加熱式たばこ遊技中OK"],
          "加熱式たばこ喫煙室" => ["🚬", "加熱式たばこ(喫煙室)"],
          "加熱式たばこ" => ["🚬", "加熱式たばこ"],
          "出玉公開" => ["📊", "出玉公開"],
        }
      %>
      <div class="mt-3 pt-3 border-t border-border">
        <span class="text-xs text-muted-foreground block mb-1.5">設備</span>
        <div class="flex flex-wrap gap-1.5">
          <% @shop.notes.split("、").each do |facility| %>
            <% next unless display_map.key?(facility) %>
            <% icon, label = display_map[facility] %>
            <span class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded-md border border-border bg-secondary text-secondary-foreground">
              <%= icon %> <%= label %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# === Date Navigation === %>
  <div class="bg-card border border-border rounded-lg p-3 mb-4">
    <div class="flex items-center justify-center gap-3">
      <%= link_to date_shop_path(@shop.slug, date: (@date - 1.day).strftime("%Y-%m-%d")),
          class: "inline-flex items-center gap-1 border border-border bg-background rounded-md px-4 py-2 text-sm text-foreground hover:bg-secondary active:scale-95 transition-all duration-150 min-h-[44px]" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        前日
      <% end %>
      <span class="font-bold text-sm text-foreground tabular-nums">
        <%= @date.strftime("%Y年%-m月%-d日") %>
        <% if @date == Date.current %>
          <span class="text-primary">(今日)</span>
        <% end %>
      </span>
      <% if @date < Date.current %>
        <%= link_to date_shop_path(@shop.slug, date: (@date + 1.day).strftime("%Y-%m-%d")),
            class: "inline-flex items-center gap-1 border border-border bg-background rounded-md px-4 py-2 text-sm text-foreground hover:bg-secondary active:scale-95 transition-all duration-150 min-h-[44px]" do %>
          翌日
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      <% end %>
      <% unless @date == Date.current %>
        <%= link_to "今日", shop_path(@shop.slug),
            class: "bg-primary text-primary-foreground rounded-md px-4 py-2 text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px] inline-flex items-center" %>
      <% end %>
    </div>
  </div>

  <%# === Vote Errors === %>
  <div id="vote_errors"></div>

  <%# === Machine Search (add new vote) === %>
  <div data-controller="machine-search"
       data-machine-search-shop-id-value="<%= @shop.id %>"
       data-machine-search-date-value="<%= @date %>"
       class="mb-4">
    <div class="relative">
      <input type="text"
             data-machine-search-target="input"
             data-action="input->machine-search#search"
             placeholder="機種名を検索して投票..."
             aria-label="機種名を検索して投票"
             class="w-full border border-input bg-background text-foreground rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent shadow-xs placeholder:text-muted-foreground"
             autocomplete="off">
    </div>
    <div data-machine-search-target="results"
         class="mt-2 bg-card border border-border rounded-lg shadow-sm empty:hidden p-3"></div>
  </div>

  <%# === Machine Filter === %>
  <div class="mb-3" data-controller="machine-filter">
    <div class="flex items-center gap-2 flex-wrap">
      <input type="text" placeholder="機種名で絞り込み..."
             data-machine-filter-target="input"
             data-action="input->machine-filter#filter"
             aria-label="機種名で絞り込み"
             class="flex-1 min-w-[160px] border border-input bg-background text-foreground rounded-md px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-ring placeholder:text-muted-foreground">
    </div>
  </div>

  <%# === Voted Machines === %>
  <div class="mb-8" data-machine-filter-target="list">
    <% if @machine_models.any? %>
      <h2 class="text-sm font-semibold text-muted-foreground mb-2">設置機種 (<%= @machine_models.size %>件)</h2>
      <%
        # タイプ別にグループ化
        grouped = @machine_models.chunk { |m| m.display_type }
      %>
      <% grouped.each do |type, machines| %>
        <div class="flex items-center gap-2 mt-4 mb-2" data-type-header>
          <span class="text-[11px] font-bold px-2 py-0.5 rounded-md <%= machines.first.display_type_badge_class %>">
            <%= machines.first.display_type_label %>
          </span>
          <span class="text-[10px] text-muted-foreground"><%= machines.size %>機種</span>
          <div class="flex-1 h-px bg-border"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% machines.each do |machine_model| %>
            <%= render "shops/machine_vote_row",
                machine_model: machine_model,
                vote_summary: @vote_summaries[machine_model.id],
                user_vote: @user_votes[machine_model.id],
                shop: @shop,
                date: @date,
                unit_count: @unit_counts[machine_model.id] %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="bg-card border border-border rounded-lg p-8 text-center">
        <div class="w-20 h-20 mx-auto mb-3">
          <%= image_tag "empty_search.svg", alt: "投票なし", class: "w-full h-full opacity-50" %>
        </div>
        <p class="text-muted-foreground text-sm">まだ投票がありません。上の検索から機種を探して投票しましょう。</p>
      </div>
    <% end %>
  </div>

  <%# === Reviews === %>
  <%= render "shops/reviews", shop: @shop, reviews: @reviews, average_rating: @average_rating, existing_review: @existing_review %>

  <%# === Comments === %>
  <%= render "shops/comments", shop: @shop, comments: @comments, date: @date %>

  <%# === Trend Chart === %>
  <% if @trend_data&.any? { |d| d[:votes] > 0 } %>
    <div class="mt-8">
      <%= render "shared/trend_chart",
          title: "過去7日間の投票トレンド",
          days_data: @trend_data %>
    </div>
  <% end %>

  <%# === Same Rate Shops === %>
  <% if @same_rate_shops.present? %>
    <div class="mt-8">
      <h2 class="text-sm font-bold text-foreground mb-2 flex items-center gap-2">
        <span class="w-1 h-4 bg-primary rounded-full"></span>
        <%= @shop.prefecture.name %>の同レート店舗
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <% @same_rate_shops.each do |other_shop| %>
          <%= link_to shop_path(other_shop.slug), class: "bg-card border border-border rounded-lg px-3 py-2.5 hover:bg-secondary hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-150 block min-h-[44px]" do %>
            <span class="text-sm font-medium text-primary"><%= other_shop.name %></span>
            <div class="flex flex-wrap items-center gap-1 mt-1">
              <% if other_shop.slot_rates.present? %>
                <% other_shop.slot_rates.each do |rate| %>
                  <span class="bg-primary/10 text-primary text-[10px] px-1.5 py-0.5 rounded-md"><%= rate %></span>
                <% end %>
              <% end %>
              <% if other_shop.exchange_rate != "unknown_rate" %>
                <span class="text-[10px] text-muted-foreground"><%= other_shop.exchange_rate_display %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
