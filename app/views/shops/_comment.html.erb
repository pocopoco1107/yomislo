<div class="bg-card border border-border rounded-lg p-3" id="<%= dom_id(comment) %>">
  <div class="flex items-center justify-between mb-1">
    <div class="flex items-center gap-2">
      <span class="text-sm font-medium text-foreground"><%= comment.display_name %></span>
      <span class="text-xs text-muted-foreground"><%= comment.created_at.strftime("%-H:%M") %></span>
    </div>
    <div id="report_flash">
      <%= button_to reports_path, params: { report: { reportable_type: "Comment", reportable_id: comment.id, reason: "inappropriate" } },
          method: :post, class: "text-xs text-muted-foreground hover:text-destructive transition-colors min-h-[44px] min-w-[44px] inline-flex items-center justify-center", data: { turbo: true, confirm: "このコメントを通報しますか？" }, aria: { label: "このコメントを通報する" } do %>
        通報
      <% end %>
    </div>
  </div>
  <p class="text-sm text-foreground whitespace-pre-wrap"><%= comment.body %></p>
</div>
