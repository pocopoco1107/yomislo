<div class="bg-card border border-border rounded-lg p-4" id="review_<%= review.id %>">
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-2">
      <span class="text-yellow-400 text-sm"><%= render_stars(review.rating) %></span>
      <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-secondary text-secondary-foreground"><%= review.category_label %></span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-xs text-muted-foreground"><%= review.created_at.strftime("%Y/%-m/%-d") %></span>
      <%= button_to reports_path, params: { report: { reportable_type: "ShopReview", reportable_id: review.id, reason: "inappropriate" } },
          method: :post, class: "text-xs text-muted-foreground hover:text-destructive transition-colors min-h-[44px] min-w-[44px] inline-flex items-center justify-center", data: { turbo: true, confirm: "このレビューを通報しますか？" }, aria: { label: "このレビューを通報する" } do %>
        通報
      <% end %>
    </div>
  </div>
  <% if review.title.present? %>
    <p class="text-sm font-bold text-foreground mb-1"><%= review.title %></p>
  <% end %>
  <p class="text-sm text-foreground whitespace-pre-wrap"><%= review.body %></p>
  <p class="text-xs text-muted-foreground mt-2"><%= review.display_name %></p>
</div>
