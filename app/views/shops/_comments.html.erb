<div id="shop_comments">
  <h2 class="text-lg font-bold text-gray-800 mb-3">コメント (<%= date.strftime("%-m/%-d") %>)</h2>

  <!-- Comment Form -->
  <turbo-frame id="comment_form">
    <div class="bg-white border border-gray-200 rounded-lg p-3 mb-4">
      <%= form_with model: Comment.new, url: comments_path, data: { turbo: true } do |f| %>
        <%= f.hidden_field :commentable_type, value: "Shop" %>
        <%= f.hidden_field :commentable_id, value: shop.id %>
        <%= f.hidden_field :target_date, value: date %>
        <div class="mb-2">
          <%= f.text_field :commenter_name, placeholder: "名前（任意）",
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-light focus:border-transparent" %>
        </div>
        <div class="flex gap-2">
          <%= f.text_area :body, placeholder: "コメントを入力...", rows: 2,
              class: "flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-light focus:border-transparent resize-none" %>
          <button type="submit" class="bg-primary text-white rounded-md px-4 py-2 text-sm font-medium hover:bg-primary-light self-end">
            投稿
          </button>
        </div>
      <% end %>
    </div>
  </turbo-frame>

  <!-- Comments List -->
  <div id="comments_list" class="space-y-2">
    <% if comments.any? %>
      <% comments.each do |comment| %>
        <%= render "shops/comment", comment: comment %>
      <% end %>
    <% else %>
      <p class="text-sm text-gray-400 text-center py-4" id="no_comments">まだコメントはありません。</p>
    <% end %>
  </div>
</div>
