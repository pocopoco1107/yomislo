<div id="shop_comments">
  <h2 class="text-lg font-bold text-foreground mb-3">コメント (<%= date.strftime("%-m/%-d") %>)</h2>

  <!-- Comment Form -->
  <turbo-frame id="comment_form">
    <div class="bg-card border border-border rounded-lg p-3 mb-4">
      <%= form_with model: Comment.new, url: comments_path, data: { turbo: true } do |f| %>
        <%= f.hidden_field :commentable_type, value: "Shop" %>
        <%= f.hidden_field :commentable_id, value: shop.id %>
        <%= f.hidden_field :target_date, value: date %>
        <div class="mb-2">
          <%= f.text_field :commenter_name, placeholder: "名前（任意）", "aria-label": "投稿者名",
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
        </div>
        <div class="flex gap-2">
          <%= f.text_area :body, placeholder: "コメントを入力...", rows: 2, "aria-label": "コメント本文",
              class: "flex-1 border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent resize-none placeholder:text-muted-foreground" %>
          <button type="submit" class="bg-primary text-primary-foreground rounded-md px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors self-end min-h-[44px]">
            投稿
          </button>
        </div>
      <% end %>
    </div>
  </turbo-frame>

  <!-- Comments List -->
  <div id="comments_list" class="space-y-2">
    <% if comments.any? %>
      <% comments.each do |comment| %>
        <%= render "shops/comment", comment: comment %>
      <% end %>
    <% else %>
      <p class="text-sm text-muted-foreground text-center py-4" id="no_comments">まだコメントはありません。</p>
    <% end %>
  </div>
</div>
