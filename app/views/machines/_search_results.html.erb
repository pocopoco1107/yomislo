<% if machines.any? %>
  <ul class="divide-y divide-border">
    <% machines.each do |machine| %>
      <li class="py-2">
        <%= form_with url: votes_path, method: :post, data: { turbo_frame: "_top" }, class: "flex items-center justify-between" do |f| %>
          <%= f.hidden_field :shop_id, value: shop_id %>
          <%= f.hidden_field :machine_model_id, value: machine.id %>
          <%= f.hidden_field :voted_on, value: date %>
          <%= f.hidden_field :reset_vote, value: nil %>
          <%= f.hidden_field :setting_vote, value: nil %>
          <span class="text-sm font-medium text-foreground"><%= machine.name %></span>
          <div class="flex gap-1.5 flex-wrap">
            <button type="submit" name="vote[reset_vote]" value="1"
                    class="bg-card text-muted-foreground border border-border hover:border-vote-yes hover:text-vote-yes rounded-md px-3 py-1.5 text-xs font-medium transition-colors min-h-[36px]">
              リセYes
            </button>
            <button type="submit" name="vote[reset_vote]" value="0"
                    class="bg-card text-muted-foreground border border-border hover:border-vote-no hover:text-vote-no rounded-md px-3 py-1.5 text-xs font-medium transition-colors min-h-[36px]">
              リセNo
            </button>
            <% (1..6).each do |s| %>
              <button type="submit" name="vote[setting_vote]" value="<%= s %>"
                      class="bg-card text-muted-foreground border border-border rounded-md w-8 h-8 text-xs font-bold transition-colors hover:bg-setting-<%= s %>/10 hover:text-setting-<%= s %> hover:border-setting-<%= s %>/50">
                <%= s %>
              </button>
            <% end %>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="py-4 flex flex-col items-center">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 180" fill="none" class="w-12 h-12 mb-1 opacity-40">
      <circle cx="90" cy="75" r="35" stroke="currentColor" stroke-width="4" fill="none" class="text-muted-foreground"/>
      <line x1="116" y1="101" x2="145" y2="130" stroke="currentColor" stroke-width="6" stroke-linecap="round" class="text-muted-foreground"/>
      <text x="90" y="85" text-anchor="middle" font-size="32" font-weight="bold" fill="currentColor" font-family="sans-serif" class="text-muted-foreground">?</text>
    </svg>
    <p class="text-sm text-muted-foreground">該当する機種が見つかりません</p>
  </div>
<% end %>
