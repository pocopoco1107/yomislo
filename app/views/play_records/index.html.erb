<% content_for(:title) { "収支カレンダー | ヨミスロ" } %>

<%# Wrap entire page in record-modal controller to receive calendar events %>
<section class="mt-4 pb-8" data-controller="record-modal"
         data-action="calendar:dateSelected->record-modal#openWithDate">

  <%# === Breadcrumb === %>
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li class="inline-flex items-center gap-1.5">
        <%= link_to "ホーム", root_path, class: "hover:text-foreground transition-colors" %>
      </li>
      <li aria-hidden="true">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </li>
      <li class="inline-flex items-center gap-1.5">
        <span class="text-foreground font-normal">収支カレンダー</span>
      </li>
    </ol>
  </nav>

  <%# === Page Title === %>
  <h1 class="text-2xl font-bold text-foreground mb-4 flex items-center gap-2">
    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    収支カレンダー
  </h1>

  <%# === Summary Cards === %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <div class="bg-surface-inset rounded-lg p-3 text-center">
      <span class="text-xs text-muted-foreground block mb-1">今月の収支</span>
      <span class="stat-number text-xl <%= @monthly_total >= 0 ? 'text-primary' : 'text-destructive' %>">
        <%= @monthly_total >= 0 ? "+" : "" %><%= number_with_delimiter(@monthly_total) %>
      </span>
    </div>
    <div class="bg-surface-inset rounded-lg p-3 text-center">
      <span class="text-xs text-muted-foreground block mb-1">勝率</span>
      <span class="stat-number text-xl text-foreground"><%= @monthly_win_rate %>%</span>
    </div>
    <div class="bg-surface-inset rounded-lg p-3 text-center">
      <span class="text-xs text-muted-foreground block mb-1">稼働日数</span>
      <span class="stat-number text-xl text-foreground">
        <%= @monthly_count %><span class="text-sm font-normal text-muted-foreground">日</span>
      </span>
    </div>
    <div class="bg-surface-inset rounded-lg p-3 text-center">
      <span class="text-xs text-muted-foreground block mb-1">累計収支</span>
      <span class="stat-number text-xl <%= @total_result >= 0 ? 'text-primary' : 'text-destructive' %>">
        <%= @total_result >= 0 ? "+" : "" %><%= number_with_delimiter(@total_result) %>
      </span>
    </div>
  </div>

  <%# === Month Navigation === %>
  <% prev_month = @current_month - 1.month %>
  <% next_month = @current_month + 1.month %>
  <div class="bg-card rounded-lg border-b border-border/50 p-3 mb-4">
    <div class="flex items-center justify-center gap-4">
      <%= link_to play_records_path(month: prev_month.strftime("%Y-%m")),
          class: "inline-flex items-center gap-1 border border-border bg-background rounded-md px-4 py-2 text-sm text-foreground hover:bg-secondary active:scale-95 transition-all duration-150 min-h-[44px]" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        前月
      <% end %>
      <span class="font-bold text-foreground text-base tabular-nums">
        <%= @current_month.strftime("%Y年%-m月") %>
      </span>
      <% if next_month.beginning_of_month <= Date.current.beginning_of_month %>
        <%= link_to play_records_path(month: next_month.strftime("%Y-%m")),
            class: "inline-flex items-center gap-1 border border-border bg-background rounded-md px-4 py-2 text-sm text-foreground hover:bg-secondary active:scale-95 transition-all duration-150 min-h-[44px]" do %>
          次月
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      <% else %>
        <span class="inline-flex items-center gap-1 border border-border bg-background rounded-md px-4 py-2 text-sm text-muted-foreground opacity-40 min-h-[44px]">
          次月
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </span>
      <% end %>
    </div>
  </div>

  <%# === Calendar Grid === %>
  <div class="bg-card rounded-lg border-b border-border/50 p-3 mb-6" data-controller="calendar">
    <%# Weekday header %>
    <div class="grid grid-cols-7 gap-px mb-1">
      <% %w[日 月 火 水 木 金 土].each_with_index do |day_name, i| %>
        <div class="text-center text-xs font-semibold py-1.5
          <%= case i when 0 then 'text-destructive' when 6 then 'text-chart-1' else 'text-muted-foreground' end %>">
          <%= day_name %>
        </div>
      <% end %>
    </div>

    <%# Calendar body %>
    <%
      first_day = @current_month.beginning_of_month
      last_day = @current_month.end_of_month
      start_padding = first_day.wday
      end_padding = 6 - last_day.wday
    %>
    <div class="grid grid-cols-7 gap-px">
      <% start_padding.times do %>
        <div class="aspect-square"></div>
      <% end %>

      <% (first_day..last_day).each do |date| %>
        <%
          daily_total = @calendar_data[date]
          is_today = date == Date.current
          is_weekend_sun = date.wday == 0
          is_weekend_sat = date.wday == 6
          is_future = date > Date.current
        %>
        <div class="aspect-square flex flex-col items-center justify-start p-0.5 sm:p-1 rounded-md transition-colors
                    <%= is_future ? 'opacity-30' : 'cursor-pointer hover:bg-secondary active:bg-primary/10' %>
                    <%= 'bg-destructive/5' if is_weekend_sun && !is_future %>
                    <%= 'bg-chart-1/5' if is_weekend_sat && !is_future %>"
             data-calendar-target="day"
             data-calendar-date="<%= date %>"
             <%= "data-action=click->calendar#select" unless is_future %>>
          <span class="text-[10px] sm:text-xs tabular-nums leading-none
                       <%= case date.wday when 0 then 'text-destructive' when 6 then 'text-chart-1' else 'text-muted-foreground' end %>
                       <%= 'font-bold text-primary' if is_today %>">
            <%= date.day %>
          </span>
          <% if daily_total %>
            <%
              display_amount = if daily_total.abs >= 10000
                                 "#{daily_total >= 0 ? '+' : ''}#{(daily_total / 1000.0).round(0)}k"
                               else
                                 "#{daily_total >= 0 ? '+' : ''}#{daily_total}"
                               end
            %>
            <span class="text-[9px] sm:text-[10px] font-bold tabular-nums leading-tight mt-0.5
                         <%= daily_total >= 0 ? 'text-primary' : 'text-destructive' %>">
              <%= display_amount %>
            </span>
          <% end %>
        </div>
      <% end %>

      <% end_padding.times do %>
        <div class="aspect-square"></div>
      <% end %>
    </div>

    <%# Hint text %>
    <p class="text-center text-[10px] text-muted-foreground mt-2">日付をタップして収支を記録</p>
  </div>

  <%# === Monthly Record List (Grouped by date+shop) === %>
  <div class="bg-card rounded-lg border-b border-border/50 p-4">
    <h2 class="text-sm font-semibold text-foreground mb-3 border-b border-border/50 pb-2 flex items-center gap-2">
      <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <%= @current_month.strftime("%Y年%-m月") %>の記録 (<%= @records.size %>件)
    </h2>

    <% if @records.any? %>
      <div class="divide-y divide-border">
        <% @grouped_records.each do |(played_on, shop_id), records| %>
          <% day_total = records.sum(&:result_amount) %>
          <div class="py-3">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2 min-w-0">
                <span class="text-xs tabular-nums text-muted-foreground shrink-0">
                  <%= played_on.strftime("%-m/%-d") %>(<%= %w[日 月 火 水 木 金 土][played_on.wday] %>)
                </span>
                <span class="text-sm font-medium text-foreground truncate"><%= favorite_mark(records.first.shop) %> <%= records.first.shop.name %></span>
              </div>
              <span class="text-sm font-bold tabular-nums shrink-0 <%= day_total >= 0 ? 'text-primary' : 'text-destructive' %>">
                <%= day_total >= 0 ? "+" : "" %><%= number_with_delimiter(day_total) %>
              </span>
            </div>

            <div class="space-y-1.5 ml-2">
              <% records.each do |record| %>
                <div class="pl-2 border-l-2 border-border">
                  <div class="flex items-center justify-between gap-2">
                    <div class="flex-1 min-w-0">
                      <span class="text-xs text-muted-foreground">
                        <%= record.machine_model ? record.machine_model.name : "店舗合算" %>
                      </span>
                      <% if record.tags.present? %>
                        <div class="flex flex-wrap gap-1 mt-0.5">
                          <% record.tags.each do |tag| %>
                            <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-secondary text-secondary-foreground"><%= tag %></span>
                          <% end %>
                        </div>
                      <% end %>
                      <% if record.memo.present? %>
                        <p class="text-[11px] text-muted-foreground mt-0.5 line-clamp-1"><%= record.memo %></p>
                      <% end %>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <span class="text-xs font-bold tabular-nums <%= record.result_amount >= 0 ? 'text-primary' : 'text-destructive' %>">
                        <%= record.result_amount >= 0 ? "+" : "" %><%= number_with_delimiter(record.result_amount) %>
                      </span>
                      <%= button_to play_record_path(record), method: :delete,
                          data: { turbo_confirm: "この記録を削除しますか？" },
                          class: "inline-flex items-center justify-center text-[10px] text-muted-foreground hover:text-destructive transition-colors min-h-[44px] min-w-[44px]" do %>
                        削除
                      <% end %>
                    </div>
                  </div>
                  <% if record.machine_model_id %>
                    <% vote_key = [record.shop_id, record.machine_model_id, record.played_on] %>
                    <%= render "play_records/vote_display",
                        user_vote: @user_votes_by_key[vote_key],
                        vote_summary: @vote_summaries_by_key[vote_key] %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="py-8 text-center">
        <div class="flex justify-center mb-3">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary font-bold text-sm">1</span>
            </div>
            <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary font-bold text-sm">2</span>
            </div>
            <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary font-bold text-sm">3</span>
            </div>
          </div>
        </div>
        <p class="text-sm font-medium text-foreground mb-1">収支記録をはじめよう</p>
        <p class="text-xs text-muted-foreground max-w-xs mx-auto">
          カレンダーの日付をタップして、店舗と結果を入力するだけ。30秒で完了します。
          複数機種をまとめて記録でき、月間収支・勝率を自動計算します。
        </p>
      </div>
    <% end %>
  </div>

  <%# ============================================
      FAB (Floating Action Button) — 今日の収支を記録
      ============================================ %>
  <button type="button"
          data-action="click->record-modal#openForToday"
          class="fixed bottom-[calc(1.5rem+env(safe-area-inset-bottom))] right-6 z-30 flex items-center gap-2 bg-primary text-primary-foreground
                 rounded-full px-5 py-3 shadow-lg hover:bg-primary/90 active:scale-95
                 transition-all duration-150 min-h-[48px]"
          aria-label="今日の収支を記録">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path d="M12 5v14m-7-7h14" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="text-sm font-medium hidden sm:inline">記録する</span>
  </button>

  <%# ============================================
      Modal — 収支記録フォーム
      ============================================ %>
  <%# Backdrop %>
  <div data-record-modal-target="backdrop"
       data-action="click->record-modal#backdropClose"
       style="display: none"
       class="fixed inset-0 bg-black/50 z-40 opacity-0 transition-opacity duration-300"></div>

  <%# Panel: bottom sheet (mobile) / center dialog (desktop) %>
  <div data-record-modal-target="panel"
       style="display: none"
       class="fixed z-50 max-h-[85vh] sm:max-h-[90vh] flex flex-col bg-card
              inset-x-0 bottom-0 rounded-t-2xl border-t border-border w-full
              sm:bottom-auto sm:top-1/2 sm:left-1/2 sm:right-auto sm:max-w-lg sm:w-[calc(100%-2rem)]
              sm:rounded-2xl sm:border sm:shadow-xl"
       id="record-modal-panel">

    <%# Handle bar (mobile) %>
    <div class="sm:hidden flex justify-center pt-2 pb-1">
      <div class="w-10 h-1 bg-muted-foreground/30 rounded-full"></div>
    </div>

    <%# Modal Header %>
    <div class="flex items-center justify-between px-4 py-3 border-b border-border sticky top-0 bg-card z-10 rounded-t-2xl sm:rounded-t-2xl">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M12 5v14m-7-7h14" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <h2 class="text-base font-semibold text-foreground">収支を記録</h2>
        <span data-record-modal-target="dateLabel"
              class="text-sm text-muted-foreground tabular-nums"></span>
      </div>
      <button type="button" data-action="click->record-modal#close"
              class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-secondary transition-colors min-w-[44px] min-h-[44px]"
              aria-label="閉じる">
        <svg class="w-5 h-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <%# Modal Body — Form %>
    <div class="px-4 py-4 overflow-y-auto overscroll-contain flex-1" data-controller="play-record-form machine-options"
         data-machine-options-url-value="<%= machines_for_shop_shops_path %>"
         data-action="shop-autocomplete:shopSelected->machine-options#update">
      <%= form_tag play_records_path, method: :post, class: "space-y-4" do %>
        <%# Hidden date (set by JS) %>
        <input type="hidden" name="played_on" value="<%= Date.current %>"
               data-record-modal-target="dateInput">

        <%# Shop autocomplete search %>
        <div data-controller="shop-autocomplete" data-shop-autocomplete-url-value="<%= autocomplete_shops_path %>"
             data-action="click@document->shop-autocomplete#closeResults" class="relative">
          <label class="text-xs font-medium text-muted-foreground block mb-1.5">店舗 <span class="text-destructive">*</span></label>
          <input type="text" placeholder="店舗名を入力して検索..." autocomplete="off"
                 data-shop-autocomplete-target="input"
                 data-action="input->shop-autocomplete#search focus->shop-autocomplete#focus"
                 class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-ring min-h-[48px] placeholder:text-muted-foreground">
          <input type="hidden" name="shop_id" required data-shop-autocomplete-target="hidden">
          <%# Autocomplete results dropdown %>
          <div data-shop-autocomplete-target="results"
               class="hidden absolute left-0 right-0 top-full mt-1 bg-card border border-border rounded-lg shadow-lg z-20 max-h-[200px] overflow-y-auto divide-y divide-border"></div>
        </div>

        <%# === Machine Entries === %>
        <div>
          <label class="text-xs font-medium text-muted-foreground block mb-1.5">機種ごとの収支</label>
          <div data-play-record-form-target="entriesContainer" class="space-y-3">
            <%# First entry %>
            <%= render "play_records/entry_fields", index: 0 %>
          </div>

          <%# Add entry button %>
          <button type="button" data-action="click->play-record-form#addEntry"
                  class="mt-2 inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors min-h-[44px] py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M12 5v14m-7-7h14" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            機種を追加
          </button>
        </div>

        <%# Template for additional entries (uses __INDEX__ placeholder) %>
        <template data-play-record-form-target="template">
          <%= render "play_records/entry_fields", index: "__INDEX__", removable: true %>
        </template>

        <%# Shared: public toggle %>
        <div class="flex items-center gap-2">
          <input type="hidden" name="is_public" value="0">
          <input type="checkbox" name="is_public" value="1" checked
              class="w-5 h-5 rounded border-border text-primary focus:ring-ring">
          <label class="text-xs text-muted-foreground">公開する(他ユーザーの統計に反映)</label>
        </div>

        <%# Submit %>
        <div class="pt-2 pb-[max(0.5rem,env(safe-area-inset-bottom))]">
          <button type="submit"
              class="w-full bg-primary text-primary-foreground rounded-lg px-4 py-3 text-base font-medium hover:bg-primary/90 active:scale-[0.98] transition-all duration-150 min-h-[48px] cursor-pointer">
            記録する
          </button>
        </div>
      <% end %>
    </div>
  </div>
</section>
