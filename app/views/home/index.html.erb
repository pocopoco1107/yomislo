<% content_for(:title) { "ヨミスロ - パチスロ設定・リセット記録 & 収支管理" } %>

<%# JSON-LD structured data for WebSite %>
<% content_for(:head) do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "ヨミスロ",
      "url": root_url,
      "description": "全国5,700店舗のパチスロ設定・リセット傾向を匿名で記録・可視化。収支カレンダーで自分のデータも管理できる無料サイト。",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "#{root_url}search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }.to_json) %>
  </script>
<% end %>

<!-- ============================================
     Hero Section (with integrated search)
     ============================================ -->
<section class="relative pb-12 pt-12 md:pb-16 md:pt-20 overflow-hidden noise-texture">

  <div class="flex flex-col gap-8 max-w-6xl mx-auto px-4">
    <div class="flex flex-col gap-4">
      <h1 class="text-balance text-4xl font-bold text-foreground md:text-6xl" style="font-family: 'Uzura', sans-serif;">
        <span class="text-primary">みんなの記録</span>で傾向が見える
      </h1>
      <p class="max-w-xl text-sm leading-relaxed text-muted-foreground md:text-base">
        収支記録で傾向をつかもう！
      </p>
    </div>

    <!-- Search in Hero -->
    <div class="w-full max-w-xl flex flex-col gap-3">
      <%# 店舗検索（リアルタイムオートコンプリート） %>
      <div data-controller="hero-search" data-hero-search-url-value="<%= autocomplete_shops_path %>" data-hero-search-type-value="shop" class="relative w-full">
        <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground pointer-events-none z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <input type="search"
               placeholder="店舗名で検索"
               autocomplete="off"
               aria-label="店舗名で検索"
               data-hero-search-target="input"
               data-action="input->hero-search#search focus->hero-search#focus"
               class="h-12 w-full rounded-lg border border-border bg-card pl-12 pr-4 text-base text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none md:h-14 md:text-lg transition-colors">
        <div data-hero-search-target="results"
             class="hidden absolute left-0 right-0 top-full mt-1 bg-card border border-border rounded-lg shadow-lg z-30 max-h-[320px] overflow-y-auto divide-y divide-border"></div>
      </div>

      <%# 機種検索（リアルタイムオートコンプリート） %>
      <div data-controller="hero-search" data-hero-search-url-value="<%= autocomplete_machines_path %>" data-hero-search-type-value="machine" class="relative w-full">
        <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground pointer-events-none z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 3l-4 4-4-4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <input type="search"
               placeholder="機種名で検索"
               autocomplete="off"
               aria-label="機種名で検索"
               data-hero-search-target="input"
               data-action="input->hero-search#search"
               class="h-12 w-full rounded-lg border border-border bg-card pl-12 pr-4 text-base text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none md:h-14 md:text-lg transition-colors">
        <div data-hero-search-target="results"
             class="hidden absolute left-0 right-0 top-full mt-1 bg-card border border-border rounded-lg shadow-lg z-30 max-h-[320px] overflow-y-auto divide-y divide-border"></div>
      </div>

      <!-- Nearby Shops -->
      <div class="mt-4" data-controller="nearby">
        <button type="button"
                data-nearby-target="button"
                data-action="click->nearby#locate"
                class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2.5 text-sm font-medium text-foreground hover:bg-secondary hover:border-primary/50 active:scale-95 transition-all duration-150 min-h-[44px]">
          <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span data-nearby-target="buttonText">現在地から探す</span>
          <svg data-nearby-target="spinner" class="hidden h-4 w-4 animate-spin text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
        <p data-nearby-target="error" class="hidden mt-2 text-sm text-destructive"></p>

        <%# 位置情報が使えない場合のフォールバック: 都道府県セレクト %>
        <div data-nearby-target="fallback" class="hidden mt-3">
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-muted-foreground shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <select data-action="change->nearby#goToPrefecture"
                    class="flex-1 h-11 rounded-lg border border-border bg-card px-3 text-sm text-foreground focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none transition-colors">
              <option value="">都道府県を選んで探す</option>
              <% @prefectures.each do |pref| %>
                <option value="<%= pref.slug %>"><%= pref.name %><%= " (#{pref.shops_count}店)" if pref.respond_to?(:shops_count) && pref.shops_count > 0 %></option>
              <% end %>
            </select>
          </div>
        </div>

        <turbo-frame id="nearby_results"></turbo-frame>
      </div>
    </div>

    <!-- Hero Stats -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
      <span><span class="stat-number text-base text-slot-red"><%= number_with_delimiter(@today_votes_count) %></span> 今日</span>
      <span class="text-border">|</span>
      <span><span class="stat-number text-base text-slot-blue"><%= number_with_delimiter(@total_votes_count) %></span> 累計</span>
      <span class="text-border">|</span>
      <span><%= number_with_delimiter(@shops_count) %> 店舗</span>
      <span><%= number_with_delimiter(@machines_count) %> 機種</span>
    </div>
  </div>
</section>

<!-- ============================================
     Two Pillars: リセ・設定 × 収支統計
     ============================================ -->
<section class="pb-10 md:pb-14 max-w-6xl mx-auto px-4">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <!-- Pillar 1: リセ・設定情報 -->
    <div class="relative overflow-hidden rounded-lg bg-card border-l-2 border-l-slot-blue p-5">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slot-blue/15">
          <svg class="h-4 w-4 text-slot-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold text-foreground">リセット・設定情報</h2>
      </div>
      <p class="text-sm text-muted-foreground mb-3">朝イチのリセット判別、夕方の高設定狙い。みんなの記録で精度が上がる。</p>
      <div class="flex items-baseline gap-2 mb-4">
        <span class="text-2xl font-bold tabular-nums text-slot-blue"><%= number_with_delimiter(@today_votes_count) %></span>
        <span class="text-xs text-muted-foreground">今日の記録</span>
      </div>
      <%= link_to root_path(anchor: "prefectures"), class: "inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline" do %>
        店舗を探して記録する
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <% end %>
    </div>

    <!-- Pillar 2: 収支統計 -->
    <div class="relative overflow-hidden rounded-lg bg-card border-l-2 border-l-slot-yellow p-5">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slot-yellow/15">
          <svg class="h-4 w-4 text-slot-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold text-foreground">収支カレンダー</h2>
      </div>
      <p class="text-sm text-muted-foreground mb-3">毎日の結果を記録するだけで月間収支・勝率を自動集計。みんなのデータが全国統計にもなる。</p>
      <div class="flex items-baseline gap-2 mb-4">
        <span class="text-2xl font-bold tabular-nums text-slot-yellow"><%= number_with_delimiter(@play_records_count) %></span>
        <span class="text-xs text-muted-foreground">累計記録</span>
      </div>
      <%= link_to play_records_path, class: "inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline" do %>
        今日の収支を記録する
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <% end %>
    </div>
  </div>
</section>

<!-- ============================================
     My Play Record Mini Card (if logged in via cookie)
     ============================================ -->
<% if @my_play_summary %>
  <section class="pb-8 md:pb-12 max-w-6xl mx-auto px-4">
    <div class="rounded-lg bg-card border-l-2 border-l-primary p-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-foreground flex items-center gap-2">
          <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          今月の収支
        </h2>
        <%= link_to play_records_path, class: "text-xs text-primary hover:underline" do %>
          詳しく見る →
        <% end %>
      </div>
      <div class="flex items-center gap-6">
        <div>
          <span class="text-xl font-bold tabular-nums <%= @my_play_summary[:total] >= 0 ? 'text-primary' : 'text-destructive' %>">
            <%= @my_play_summary[:total] >= 0 ? '+' : '' %><%= number_with_delimiter(@my_play_summary[:total]) %>円
          </span>
        </div>
        <div class="text-xs text-muted-foreground">
          稼働<%= @my_play_summary[:days] %>日 / 勝率<%= @my_play_summary[:win_rate] %>%
        </div>
      </div>
      <div class="mt-2">
        <%= link_to play_records_path, class: "inline-flex items-center justify-center gap-1 bg-primary text-primary-foreground px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px]" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 4v16m8-8H4" stroke-linecap="round"/></svg>
          今日の収支を記録
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<!-- ============================================
     Weekly High Setting Machines
     ============================================ -->
<section class="pb-12 md:pb-16 max-w-6xl mx-auto px-4">
  <div class="rounded-lg bg-card border-b border-border/50 p-4 max-w-lg">
    <div class="mb-3 flex items-center gap-2">
      <div class="h-2 w-2 rounded-full bg-slot-red"></div>
      <h2 class="text-sm font-semibold text-foreground">今週の高設定報告が多い機種</h2>
    </div>
    <% if @weekly_high_setting_machines.any? %>
      <ol class="space-y-2">
        <% @weekly_high_setting_machines.each_with_index do |item, i| %>
          <li class="flex items-center gap-2">
            <span class="text-xs font-bold tabular-nums w-4 shrink-0
              <%= case i when 0 then 'text-yellow-500' when 1 then 'text-muted-foreground' when 2 then 'text-amber-700' else 'text-muted-foreground' end %>">
              <%= i + 1 %>
            </span>
            <%= link_to machine_path(item[:machine].slug), class: "text-sm font-medium text-primary hover:underline truncate flex-1", data: { turbo_frame: "_top" } do %>
              <%= item[:machine].name %>
            <% end %>
            <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-destructive/10 text-destructive shrink-0">
              高設定 <%= item[:pct] %>%
            </span>
            <span class="text-xs tabular-nums text-muted-foreground shrink-0"><%= item[:high_count] %>/<%= item[:total_count] %>件</span>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="text-xs text-muted-foreground py-4 text-center">今週の設定データはまだありません</p>
    <% end %>
  </div>
</section>

<!-- ============================================
     Favorite Shops
     ============================================ -->
<section class="pb-10 md:pb-14 max-w-6xl mx-auto px-4" data-controller="favorites-list">
  <div data-favorites-list-target="container" class="hidden">
    <div class="mb-4 flex items-center gap-2">
      <svg class="h-5 w-5 text-slot-yellow" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <h2 class="text-lg font-semibold tracking-tight text-foreground">お気に入り店舗</h2>
    </div>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3" data-favorites-list></ul>
  </div>
</section>

<!-- ============================================
     Trending Shops
     ============================================ -->
<% if @recommendations.present? %>
  <section class="pb-12 md:pb-16 max-w-6xl mx-auto px-4">
    <div class="mb-4 flex items-center gap-2">
      <svg class="h-5 w-5 text-slot-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
        <polyline points="17 6 23 6 23 12"/>
      </svg>
      <h2 class="text-lg font-semibold tracking-tight text-foreground">トレンド店舗</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @recommendations.each_with_index do |rec, i| %>
        <%= link_to shop_path(rec.shop.slug), class: "group flex flex-col gap-2 rounded-lg bg-card border-b border-border/50 p-4 transition-all duration-150 hover:border-primary/50 hover:-translate-y-px hover:shadow-sm", data: { turbo_frame: "_top" } do %>
          <div class="flex items-start justify-between gap-2">
            <div class="flex items-center gap-2 min-w-0">
              <span class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold
                <%= case i when 0 then 'bg-primary/15 text-primary' when 1 then 'bg-primary/10 text-primary' else 'bg-muted text-muted-foreground' end %>">
                <%= i + 1 %>
              </span>
              <p class="font-medium text-sm text-foreground truncate group-hover:text-primary transition-colors"><%= favorite_mark(rec.shop) %> <%= rec.shop.name %></p>
            </div>
            <% if rec.shop.prefecture %>
              <span class="shrink-0 text-[10px] text-muted-foreground"><%= rec.shop.prefecture.name %></span>
            <% end %>
          </div>
          <% if rec.reasons.any? %>
            <div class="flex flex-wrap gap-1">
              <% rec.reasons.first(2).each do |reason| %>
                <%
                  badge_class = case reason[:type]
                  when :high_setting then "bg-destructive/10 text-destructive"
                  when :reset_rate then "bg-primary/10 text-primary"
                  when :vote_volume then "bg-chart-1/10 text-chart-1"
                  when :review_rating then "bg-secondary text-secondary-foreground"
                  else "bg-muted text-muted-foreground"
                  end
                %>
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full <%= badge_class %>">
                  <%= reason[:label] %>
                </span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<!-- ============================================
     Weekly Voter Ranking + Status
     ============================================ -->
<section class="pb-12 md:pb-16 max-w-6xl mx-auto px-4">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="rounded-lg bg-card border-b border-border/50 p-4">
      <div class="mb-3 flex items-center gap-2">
        <div class="h-2 w-2 rounded-full bg-slot-yellow"></div>
        <h2 class="text-sm font-semibold text-foreground">週間記録ランキング</h2>
      </div>
      <% if @weekly_ranking.any? %>
        <ol class="space-y-2">
          <% @weekly_ranking.each do |entry| %>
            <li class="flex items-center gap-2">
              <span class="text-xs font-bold tabular-nums w-4 shrink-0 <%= case entry[:rank] when 1 then 'text-yellow-500' when 2 then 'text-muted-foreground' when 3 then 'text-amber-700' else 'text-muted-foreground' end %>">
                <%= entry[:rank] %>
              </span>
              <span class="text-sm font-medium text-foreground flex-1 truncate"><%= entry[:label] %></span>
              <span class="text-xs tabular-nums text-muted-foreground shrink-0"><%= entry[:count] %>件</span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-xs text-muted-foreground py-4 text-center">今週の記録データはまだありません</p>
      <% end %>
      <div class="mt-3 text-center">
        <%= link_to "すべて見る →", rankings_path, class: "text-xs text-primary hover:underline" %>
      </div>
    </div>

    <div class="rounded-lg bg-surface-inset p-4 flex flex-col items-center justify-center text-center">
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-slot-yellow/15 mb-3">
        <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M12 15l-2 5-1-3-3-1 5-2zM12 15l2 5 1-3 3-1-5-2z" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M8 7a4 4 0 118 0 4 4 0 01-8 0z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h2 class="text-sm font-semibold text-foreground mb-1">称号を獲得しよう</h2>
      <p class="text-xs text-muted-foreground mb-4">記録を続けると称号がランクアップ。的中率もトラッキング。</p>
      <%= link_to "ステータスを見る", voter_status_path, class: "inline-flex items-center justify-center bg-primary text-primary-foreground px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px]" %>
    </div>
  </div>
</section>

<!-- ============================================
     Weekly Trend Chart
     ============================================ -->
<% if @trend_data&.any? { |d| d[:votes] > 0 } %>
  <section class="pb-12 md:pb-16 max-w-6xl mx-auto px-4">
    <%= render "shared/trend_chart",
        title: "過去7日間の全国記録推移",
        days_data: @trend_data,
        show_reset: false,
        show_setting: false,
        compact: true %>
  </section>
<% end %>

<!-- ============================================
     Prefecture Grid
     ============================================ -->
<section id="prefectures" class="pb-12 md:pb-16 max-w-6xl mx-auto px-4">
  <h2 class="text-lg font-semibold tracking-tight text-foreground mb-4">都道府県から探す</h2>

  <%
    regions = {
      "北海道・東北" => %w[北海道 青森県 岩手県 宮城県 秋田県 山形県 福島県],
      "関東" => %w[茨城県 栃木県 群馬県 埼玉県 千葉県 東京都 神奈川県],
      "中部" => %w[新潟県 富山県 石川県 福井県 山梨県 長野県 岐阜県 静岡県 愛知県],
      "近畿" => %w[三重県 滋賀県 京都府 大阪府 兵庫県 奈良県 和歌山県],
      "中国" => %w[鳥取県 島根県 岡山県 広島県 山口県],
      "四国" => %w[徳島県 香川県 愛媛県 高知県],
      "九州・沖縄" => %w[福岡県 佐賀県 長崎県 熊本県 大分県 宮崎県 鹿児島県 沖縄県]
    }
    prefectures_by_name = @prefectures.index_by(&:name)
  %>

  <%
    region_colors = %w[bg-slot-blue bg-slot-yellow bg-slot-green bg-slot-red bg-slot-blue bg-slot-yellow bg-slot-green]
  %>
  <% regions.each_with_index do |(region_name, pref_names), region_idx| %>
    <div class="mb-2" data-controller="accordion">
      <button type="button" data-action="click->accordion#toggle"
              class="w-full flex items-center justify-between text-sm font-semibold text-muted-foreground py-3 hover:text-foreground active:bg-secondary/50 transition-all duration-150 min-h-[44px] rounded-md px-2">
        <div class="flex items-center gap-2">
          <div class="h-4 w-1 rounded-full <%= region_colors[region_idx] %>"></div>
          <span><%= region_name %></span>
        </div>
        <svg data-accordion-target="icon" class="w-4 h-4 text-muted-foreground transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div data-accordion-target="content" class="hidden mt-1.5 mb-2">
        <div class="flex flex-wrap gap-1.5">
          <% pref_names.each do |pref_name| %>
            <% pref = prefectures_by_name[pref_name] %>
            <% if pref %>
              <%= link_to prefecture_path(pref.slug),
                  class: "bg-card rounded-md px-3 py-2 text-xs text-center hover:bg-primary hover:text-primary-foreground active:scale-95 transition-all duration-150 min-h-[40px] inline-flex items-center gap-1 shadow-sm" do %>
                <span class="text-foreground whitespace-nowrap"><%= pref_name.sub(/[県]$/, '') %></span>
                <% if pref.respond_to?(:shops_count) && pref.shops_count > 0 %>
                  <span class="text-[10px] text-muted-foreground"><%= pref.shops_count %></span>
                <% end %>
              <% end %>
            <% else %>
              <span class="bg-muted border border-border rounded-md px-3 py-2 text-xs text-muted-foreground whitespace-nowrap">
                <%= pref_name.sub(/[県]$/, '') %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>

<!-- ============================================
     Recent Active Shops
     ============================================ -->
<section class="pb-16 md:pb-24 max-w-6xl mx-auto px-4">
  <h2 class="text-lg font-semibold tracking-tight text-foreground mb-4">最近の更新店舗</h2>
  <% if @recent_shops.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @recent_shops.each do |shop| %>
        <%= link_to shop_path(shop.slug), class: "group rounded-lg bg-card border-b border-border/50 p-3 hover:-translate-y-px hover:shadow-sm transition-all duration-150 block", data: { turbo_frame: "_top" } do %>
          <div class="flex items-start justify-between gap-2">
            <p class="font-medium text-sm text-foreground truncate flex-1 group-hover:text-primary transition-colors"><%= favorite_mark(shop) %> <%= shop.name %></p>
            <% if shop.exchange_rate != "unknown_rate" %>
              <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded-full
                <%= case shop.exchange_rate
                    when 'equal_rate' then 'bg-primary/10 text-primary'
                    when 'rate_56' then 'bg-chart-4/10 text-chart-4'
                    when 'rate_50' then 'bg-chart-5/10 text-chart-5'
                    when 'non_equal' then 'bg-muted text-muted-foreground'
                    end %>">
                <%= shop.exchange_rate_display %>
              </span>
            <% end %>
          </div>
          <p class="text-xs text-muted-foreground mt-1"><%= shop.prefecture.name %></p>
          <div class="flex flex-wrap items-center gap-1 mt-1">
            <% if shop.slot_rates.present? %>
              <% shop.slot_rates.each do |rate| %>
                <span class="bg-primary/10 text-primary text-[10px] font-medium px-1.5 py-0.5 rounded-full"><%= rate %></span>
              <% end %>
            <% end %>
            <% if shop.business_hours.present? %>
              <span class="text-[10px] text-muted-foreground"><%= shop.business_hours %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-col items-center py-8">
      <svg class="w-12 h-12 text-muted-foreground/40 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-sm text-muted-foreground">まだ店舗データがありません。</p>
    </div>
  <% end %>
</section>
