<% content_for(:title) { "全国店舗検索 - スロリセnavi" } %>

<section class="mt-6 mb-8">
  <%# パンくずリスト %>
  <nav aria-label="breadcrumb" class="mb-5">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li class="inline-flex items-center gap-1.5">
        <%= link_to root_path, class: "hover:text-foreground transition-colors" do %>
          <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
          <span>ホーム</span>
        <% end %>
      </li>
      <li aria-hidden="true">
        <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </li>
      <li>
        <span class="text-foreground font-normal" aria-current="page">全国店舗検索</span>
      </li>
    </ol>
  </nav>

  <%# ページヘッダー %>
  <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground mb-6">全国店舗検索</h1>

  <%# 検索フォーム %>
  <%= form_tag search_path, method: :get, class: "mb-8" do %>
    <%# フリーワード検索 %>
    <div class="relative mb-4">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-muted-foreground pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input type="text" name="q" value="<%= params[:q] %>"
             placeholder="店舗名で検索..."
             aria-label="店舗名で検索"
             class="w-full min-h-[44px] rounded-md border border-input bg-transparent pl-9 pr-3 py-2 text-sm shadow-xs placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] outline-none transition-[color,box-shadow]"
             autocomplete="off">
    </div>

    <%# フィルタパネル %>
    <div class="bg-card border border-border rounded-lg p-5 shadow-sm">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <%# 都道府県 %>
        <div class="sm:col-span-2 lg:col-span-3">
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">都道府県</h4>
          <select name="prefectures[]" multiple
                  class="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-xs focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] outline-none transition-[color,box-shadow]"
                  size="5">
            <% @prefectures.each do |pref| %>
              <option value="<%= pref.slug %>" <%= "selected" if Array(params[:prefectures]).include?(pref.slug) %>>
                <%= pref.name %>
              </option>
            <% end %>
          </select>
          <p class="text-[10px] text-muted-foreground mt-1.5">Ctrl/Cmd + クリックで複数選択</p>
        </div>

        <%# 換金率 %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">換金率</h4>
          <div class="space-y-2">
            <% [["equal_rate", "等価"], ["rate_56", "5.6枚交換"], ["rate_50", "5.0枚交換"], ["non_equal", "非等価"]].each do |value, label| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" name="exchange_rates[]" value="<%= value %>"
                       <%= "checked" if Array(params[:exchange_rates]).include?(value) %>
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# レート %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">レート</h4>
          <div class="space-y-2">
            <% %w[20スロ 5スロ 2スロ 1スロ].each do |rate| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" name="rates[]" value="<%= rate %>"
                       <%= "checked" if Array(params[:rates]).include?(rate) %>
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= rate %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# 設備 %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">設備</h4>
          <div class="space-y-2">
            <% [["加熱式たばこ遊技OK", "加熱式たばこ遊技OK"], ["Wi-Fi", "Wi-Fi"], ["充電器", "充電器"], ["parking", "駐車場あり"]].each do |value, label| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" name="facilities[]" value="<%= value %>"
                       <%= "checked" if Array(params[:facilities]).include?(value) %>
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# 開店時間 %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">開店時間</h4>
          <div class="space-y-2">
            <% [["9", "9時台"], ["10", "10時台"]].each do |value, label| %>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" name="opening_hours[]" value="<%= value %>"
                       <%= "checked" if Array(params[:opening_hours]).include?(value) %>
                       class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
                <span class="text-xs text-foreground group-hover:text-primary transition-colors"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# 朝入場ルール %>
        <div>
          <h4 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider mb-2.5">朝入場ルール</h4>
          <div class="space-y-2">
            <label class="flex items-center gap-2.5 cursor-pointer group">
              <input type="checkbox" name="morning_entry" value="yes"
                     <%= "checked" if params[:morning_entry] == "yes" %>
                     class="size-4 shrink-0 rounded-[4px] border border-input shadow-xs accent-primary">
              <span class="text-xs text-foreground group-hover:text-primary transition-colors">ルールあり</span>
            </label>
          </div>
        </div>

      </div>

      <%# 検索・クリアボタン %>
      <div class="mt-5 pt-4 border-t border-border flex items-center gap-3">
        <button type="submit"
                class="inline-flex items-center justify-center gap-2 rounded-md bg-primary text-primary-foreground min-h-[44px] px-5 py-2 text-sm font-medium shadow-xs hover:bg-primary/90 transition-all">
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          検索
        </button>
        <%= link_to "条件をクリア", search_path, class: "text-xs text-muted-foreground hover:text-foreground transition-colors underline underline-offset-2 inline-flex items-center min-h-[44px] px-2" %>
      </div>
    </div>
  <% end %>

  <%# 結果ヘッダー %>
  <div class="mb-4 flex items-center justify-between">
    <p class="text-sm text-muted-foreground">
      検索結果: <strong class="text-foreground tabular-nums"><%= @shops.total_count %></strong>件
    </p>
    <% if @shops.total_pages > 1 %>
      <p class="text-xs text-muted-foreground tabular-nums"><%= @shops.current_page %> / <%= @shops.total_pages %> ページ</p>
    <% end %>
  </div>

  <%# 検索結果 %>
  <% if @shops.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
      <% @shops.each do |shop| %>
        <%= link_to shop_path(shop.slug), class: "bg-card border border-border rounded-lg p-3.5 hover:border-primary/50 transition-colors block" do %>
          <div class="flex items-start justify-between gap-2">
            <p class="font-semibold text-sm text-foreground truncate flex-1"><%= shop.name %></p>
            <% if shop.exchange_rate != "unknown_rate" %>
              <span class="shrink-0 text-[10px] font-medium px-2 py-0.5 rounded-md
                <%= case shop.exchange_rate
                    when 'equal_rate' then 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400'
                    when 'rate_56' then 'bg-amber-500/10 text-amber-600 dark:text-amber-400'
                    when 'rate_50' then 'bg-orange-500/10 text-orange-600 dark:text-orange-400'
                    when 'non_equal' then 'bg-secondary text-muted-foreground'
                    end %>">
                <%= shop.exchange_rate_display %>
              </span>
            <% end %>
          </div>
          <p class="text-xs text-muted-foreground mt-1"><%= shop.prefecture.name %></p>
          <% if shop.address.present? %>
            <p class="text-[10px] text-muted-foreground/70 mt-0.5 truncate"><%= shop.address %></p>
          <% end %>
          <div class="flex flex-wrap items-center gap-1 mt-2">
            <% if shop.slot_rates.present? %>
              <% shop.slot_rates.each do |rate| %>
                <span class="bg-blue-500/10 text-blue-600 dark:text-blue-400 text-[10px] font-medium px-1.5 py-0.5 rounded-md"><%= rate %></span>
              <% end %>
            <% end %>
            <% if shop.business_hours.present? %>
              <span class="text-[10px] text-muted-foreground"><%= shop.business_hours %></span>
            <% end %>
            <% if shop.notes.present? %>
              <% shop_facilities = shop.notes.split("、") %>
              <% if shop_facilities.include?("加熱式たばこ遊技OK") %>
                <span class="bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 text-[10px] font-medium px-1.5 py-0.5 rounded-md">遊技中OK</span>
              <% elsif shop_facilities.include?("加熱式たばこ喫煙室") %>
                <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">喫煙室</span>
              <% elsif shop_facilities.include?("加熱式たばこ") %>
                <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">加熱式</span>
              <% end %>
              <% if shop_facilities.include?("Wi-Fi") %>
                <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">Wi-Fi</span>
              <% end %>
              <% if shop_facilities.include?("充電器") %>
                <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md">充電</span>
              <% end %>
            <% end %>
            <% if shop.parking_spaces.present? && shop.parking_spaces > 0 %>
              <span class="bg-secondary text-muted-foreground text-[10px] px-1.5 py-0.5 rounded-md tabular-nums">P<%= shop.parking_spaces %></span>
            <% end %>
            <% if shop.morning_entry.present? %>
              <span class="bg-amber-500/10 text-amber-600 dark:text-amber-400 text-[10px] font-medium px-1.5 py-0.5 rounded-md">朝整理券</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# ページネーション %>
    <% if @shops.total_pages > 1 %>
      <nav class="mt-8 flex justify-center">
        <%= paginate @shops, window: 2, outer_window: 1 %>
      </nav>
    <% end %>
  <% else %>
    <div class="bg-card border border-border rounded-lg p-10 text-center">
      <svg class="size-12 mx-auto mb-3 text-muted-foreground/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <p class="text-foreground font-medium">条件に一致する店舗がありません</p>
      <p class="text-sm text-muted-foreground mt-1.5">検索条件を変更してお試しください</p>
    </div>
  <% end %>
</section>
