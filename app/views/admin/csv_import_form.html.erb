<div style="padding: 20px;">
  <h2><%= resource_name %>CSVインポート</h2>

  <%= form_tag path, multipart: true, method: :post do %>
    <div style="margin: 20px 0;">
      <label for="csv_file" style="display: block; margin-bottom: 8px; font-weight: bold;">CSVファイルを選択</label>
      <%= file_field_tag :csv_file, accept: ".csv" %>
    </div>

    <%= submit_tag "インポート", style: "background: #1e40af; color: white; padding: 8px 20px; border: none; border-radius: 4px; cursor: pointer;" %>
  <% end %>

  <div style="margin-top: 30px; padding: 15px; background: #f5f5f5; border-radius: 4px;">
    <h3>CSVフォーマット</h3>
    <% if resource_name == "店舗" %>
      <p>ヘッダー行必須。以下のカラムに対応:</p>
      <code>name, prefecture_slug, prefecture_name, address, slug, slot_rates, exchange_rate, total_machines, slot_machines, business_hours, holidays, former_event_days, notes</code>
      <ul style="margin-top: 10px; font-size: 12px; color: #666;">
        <li>name (必須): 店舗名</li>
        <li>prefecture_slug or prefecture_name (必須): 都道府県</li>
        <li>address: 住所</li>
        <li>slug: URL用スラッグ (空欄なら自動生成)</li>
        <li>slot_rates: レート ("|"区切り。例: "20スロ|5スロ")</li>
        <li>exchange_rate: unknown_rate / equal_rate / rate_56 / rate_50 / non_equal</li>
        <li>total_machines / slot_machines: 台数 (数値)</li>
      </ul>
    <% else %>
      <p>ヘッダー行必須。以下のカラムに対応:</p>
      <code>name, maker, machine_type, spec_type, slug, released_on</code>
      <ul style="margin-top: 10px; font-size: 12px; color: #666;">
        <li>name (必須): 機種名</li>
        <li>maker: メーカー名</li>
        <li>machine_type: slot / pachislot</li>
        <li>spec_type: type_at / type_art / type_a_plus_at / type_a</li>
        <li>slug: URL用スラッグ (空欄なら自動生成)</li>
        <li>released_on: 発売日 (YYYY-MM-DD)</li>
      </ul>
    <% end %>
  </div>
</div>
