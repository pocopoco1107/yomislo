<%= turbo_stream.prepend "comments_list" do %>
  <%= render "shops/comment", comment: @comment %>
<% end %>

<%= turbo_stream.remove "no_comments" %>

<%= turbo_stream.replace "comment_form" do %>
  <turbo-frame id="comment_form">
    <div class="bg-white border border-gray-200 rounded-lg p-3 mb-4">
      <%= form_with model: Comment.new, url: comments_path, data: { turbo: true } do |f| %>
        <%= f.hidden_field :commentable_type, value: @comment.commentable_type %>
        <%= f.hidden_field :commentable_id, value: @comment.commentable_id %>
        <%= f.hidden_field :target_date, value: @comment.target_date %>
        <div class="flex gap-2">
          <%= f.text_area :body, placeholder: "コメントを入力...", rows: 2,
              class: "flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-light focus:border-transparent resize-none" %>
          <button type="submit" class="bg-primary text-white rounded-md px-4 py-2 text-sm font-medium hover:bg-primary-light self-end">
            投稿
          </button>
        </div>
      <% end %>
    </div>
  </turbo-frame>
<% end %>
